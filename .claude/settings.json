{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "PowerShell(git status *)",
      "PowerShell(git diff *)",
      "PowerShell(git log *)"
    ],
    "ask": [
      "PowerShell(git commit *)",
      "PowerShell(git push *)",
      "PowerShell(git reset *)",
      "PowerShell(git clean *)",
      "PowerShell(Invoke-WebRequest *)",
      "PowerShell(Invoke-RestMethod *)",
      "PowerShell(curl *)",
      "PowerShell(wget *)",
      "Edit(.obsidian/**)",
      "Write(.obsidian/**)",
      "Edit(.claudian/**)",
      "Write(.claudian/**)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(.git/**)",
      "Write(.git/**)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(.claudian/sessions/**)",
      "Read(.claudian/feishu-sync-state*.json)",
      "PowerShell(Remove-Item -Recurse -Force *)",
      "PowerShell(Format-Volume *)",
      "PowerShell(Stop-Computer *)",
      "PowerShell(Restart-Computer *)"
    ]
  }
}

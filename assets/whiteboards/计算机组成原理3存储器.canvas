                  },
                  {
                      "id":  "n_z1_46",
                      "type":  "text",
                      "x":  100,
                      "y":  2120,
                      "width":  120,
                      "height":  60,
                      "text":  "存储器",
                      "color":  "#5178c6"
                  },
                  {
